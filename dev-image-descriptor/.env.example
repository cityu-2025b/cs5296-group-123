# === xAI Grok API ===
# Obtain an API key from https://console.x.ai/ (or your provider) and set it here or in your environment
XAI_API_KEY=your_xai_api_key_here
# Optional API base URL override. Default is xAI.
XAI_BASE_URL=https://api.x.ai/v1
# Model name (adjust as needed)
XAI_MODEL=grok-4-1-fast-non-reasoning

# Vision detail: auto | low | high
XAI_IMAGE_DETAIL=high

# gRPC timeout in seconds
XAI_TIMEOUT=3600

# === Script runtime defaults ===
IMAGE_INPUT=./image
IMAGE_OUTPUT=./image_descriptions.json
