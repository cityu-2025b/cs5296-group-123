# === xAI Grok API ===
# Obtain an API key from https://console.x.ai/ (or your provider) and set it here or in your environment
XAI_API_KEY=your_xai_api_key_here
# If your provider uses an OpenAI-compatible endpoint, set it here. Default is xAI.
XAI_BASE_URL=https://api.x.ai/v1
# Model name (adjust as needed)
XAI_MODEL=grok-4-1-fast-non-reasoning

# Vision detail: auto | low | high
XAI_IMAGE_DETAIL=high

# gRPC timeout in seconds
XAI_TIMEOUT=3600

# === Image Processing Lambda ===
# DynamoDB table for storing image descriptions before OpenSearch ingestion
IMAGE_STORE_DYNAMODB_TABLE=image_store

# Local JSON log output used by the describer (kept for debugging/audit)
IMAGE_DESCRIPTION_LOG=./image_descriptions.json

# Optional fallback used by CLI/local runs in grok_image_describer.py
IMAGE_OUTPUT=./image_descriptions.json
